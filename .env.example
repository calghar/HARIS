# HARIS environment variables
# Copy to .env and fill in values for your engagement.

# Target
HARIS_TARGET_URL=https://example.com
HARIS_PROFILE=quick

# Authentication (set the method in config YAML, values here)
HARIS_AUTH_HEADER=
HARIS_AUTH_COOKIE=
HARIS_AUTH_USERNAME=
HARIS_AUTH_PASSWORD=

# Output
HARIS_OUTPUT_DIR=./reports
HARIS_LOG_LEVEL=INFO

# Template management
HARIS_TEMPLATE_DIR=./templates

# LLM backends (set one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434
